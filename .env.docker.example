# Compose / PostgreSQL
APP_PORT=3000
POSTGRES_PORT=5432
POSTGRES_USER=maidah
POSTGRES_PASSWORD=maidah
POSTGRES_DB=maidah
TZ=Asia/Almaty

# App server
PORT=3000
PGHOST=db
PGPORT=5432
PGUSER=maidah
PGPASSWORD=maidah
PGDATABASE=maidah
PGPOOL_MAX=10
PGPOOL_IDLE_TIMEOUT_MS=30000

STATS_CACHE_TTL_MS=30000
RESTAURANTS_CACHE_TTL_MS=300000
INCLUDED_ORDER_STATUSES=archived
ANALYTICS_TIME_ZONE=Asia/Almaty

# all | company | store
RESTAURANT_VISIBILITY=company
DEFAULT_COMPANY_ID=sheker-coffee
DEFAULT_STORE_ID=
